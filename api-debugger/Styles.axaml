<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Card/Panel Style -->
    <Style Selector="Border.card">
        <Setter Property="Background" Value="#2d2d2d" />
        <Setter Property="BorderBrush" Value="#3d3d3d" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <Style Selector="Border.card-compact">
        <Setter Property="Background" Value="#2d2d2d" />
        <Setter Property="BorderBrush" Value="#3d3d3d" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="12" />
    </Style>

    <!-- Section Header -->
    <Style Selector="TextBlock.section-header">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="#a0a0a0" />
        <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

    <!-- Label Style -->
    <Style Selector="TextBlock.label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="#909090" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Code/Mono Text -->
    <Style Selector="TextBox.code">
        <Setter Property="FontFamily" Value="Cascadia Code, Consolas, monospace" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Background" Value="#1e1e1e" />
        <Setter Property="BorderBrush" Value="#3d3d3d" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>

    <Style Selector="ListBox.code">
        <Setter Property="FontFamily" Value="Cascadia Code, Consolas, monospace" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Background" Value="#1e1e1e" />
        <Setter Property="BorderBrush" Value="#3d3d3d" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="4" />
    </Style>

    <!-- Status Colors -->
    <Style Selector="TextBlock.status-connected">
        <Setter Property="Foreground" Value="#4ec9b0" />
    </Style>

    <Style Selector="TextBlock.status-disconnected">
        <Setter Property="Foreground" Value="#f14c4c" />
    </Style>

    <Style Selector="TextBlock.status-pending">
        <Setter Property="Foreground" Value="#dcdcaa" />
    </Style>

    <!-- Primary Button -->
    <Style Selector="Button.primary">
        <Setter Property="Background" Value="#0078d4" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>

    <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#1084d8" />
    </Style>

    <!-- Secondary Button -->
    <Style Selector="Button.secondary">
        <Setter Property="Background" Value="#3d3d3d" />
        <Setter Property="Foreground" Value="#e0e0e0" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>

    <!-- Image Container -->
    <Style Selector="Border.image-container">
        <Setter Property="Background" Value="#1e1e1e" />
        <Setter Property="BorderBrush" Value="#3d3d3d" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>

    <!-- ComboBox improvements -->
    <Style Selector="ComboBox">
        <Setter Property="CornerRadius" Value="4" />
    </Style>

    <!-- TextBox improvements -->
    <Style Selector="TextBox">
        <Setter Property="CornerRadius" Value="4" />
    </Style>

</Styles>
