<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MusicBeeRemote.ApiDebugger.ViewModels"
        xmlns:models="using:MusicBeeRemote.ApiDebugger.Models"
        x:Class="MusicBeeRemote.ApiDebugger.Views.ComparisonResultsWindow"
        x:DataType="vm:ComparisonResultsViewModel"
        Title="Session Comparison Results"
        Width="1000" Height="650"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="#1e1e1e">

    <Design.DataContext>
        <vm:ComparisonResultsViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="16">
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="SESSION COMPARISON RESULTS" Classes="section-header" />
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <TextBlock Text="A:" Foreground="#808080" FontWeight="SemiBold" Margin="0,0,8,0" VerticalAlignment="Center" />
                <TextBlock Text="{Binding SessionAName}" Foreground="#4EC9B0" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBlock Text="{Binding SessionAPairCount, StringFormat=' ({0} pairs)'}" Foreground="#808080" VerticalAlignment="Center" />
                <TextBlock Text="   vs   " Foreground="#808080" VerticalAlignment="Center" />
                <TextBlock Text="B:" Foreground="#808080" FontWeight="SemiBold" Margin="0,0,8,0" VerticalAlignment="Center" />
                <TextBlock Text="{Binding SessionBName}" Foreground="#DCDCAA" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBlock Text="{Binding SessionBPairCount, StringFormat=' ({0} pairs)'}" Foreground="#808080" VerticalAlignment="Center" />
            </StackPanel>
        </StackPanel>

        <!-- Summary -->
        <Border Grid.Row="1" Background="#252526" CornerRadius="4" Padding="12" Margin="0,0,0,12">
            <TextBlock Text="{Binding SummaryText}" Foreground="#e0e0e0" FontSize="14" />
        </Border>

        <!-- Filter Controls -->
        <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,12">
            <!-- Left: Toggle buttons -->
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button Content="Show All" Command="{Binding ShowAllCommand}"
                        Classes="secondary" Margin="0,0,8,0" />
                <Button Content="Show Differences Only" Command="{Binding ShowDiffsOnlyCommand}"
                        Classes="primary" />
            </StackPanel>

            <!-- Right: Context filter -->
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <TextBlock Text="Filter by context:" Foreground="#808080" VerticalAlignment="Center" Margin="0,0,8,0" />
                <ComboBox ItemsSource="{Binding AvailableContexts}"
                          SelectedItem="{Binding SelectedContext}"
                          MinWidth="200"
                          Background="#2d2d2d"
                          Foreground="#e0e0e0" />
            </StackPanel>
        </Grid>

        <!-- Results Grid -->
        <Border Grid.Row="3" Background="#252526" CornerRadius="6" BorderBrush="#3d3d3d" BorderThickness="1">
            <DataGrid ItemsSource="{Binding FilteredResults}"
                      SelectedItem="{Binding SelectedResult}"
                      AutoGenerateColumns="False"
                      CanUserReorderColumns="False"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      Background="Transparent"
                      RowBackground="#252526">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#A" Binding="{Binding SequenceA}" Width="50" />
                    <DataGridTextColumn Header="#B" Binding="{Binding SequenceB}" Width="50" />
                    <DataGridTextColumn Header="Context" Binding="{Binding Context}" Width="180" />
                    <DataGridTemplateColumn Header="Request" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="models:PairComparisonResult">
                                <TextBlock Text="{Binding RequestStatus}"
                                           Foreground="{Binding RequestStatus, Converter={x:Static vm:ComparisonStatusToBrushConverter.Instance}}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Response" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="models:PairComparisonResult">
                                <TextBlock Text="{Binding ResponseStatus}"
                                           Foreground="{Binding ResponseStatus, Converter={x:Static vm:ComparisonStatusToBrushConverter.Instance}}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Time A" Binding="{Binding ResponseTimeMsA, StringFormat='{}{0}ms'}" Width="70" />
                    <DataGridTextColumn Header="Time B" Binding="{Binding ResponseTimeMsB, StringFormat='{}{0}ms'}" Width="70" />
                    <DataGridTemplateColumn Header="" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="models:PairComparisonResult">
                                <Button Content="View"
                                        Command="{Binding $parent[DataGrid].((vm:ComparisonResultsViewModel)DataContext).ViewDiffCommand}"
                                        CommandParameter="{Binding}"
                                        IsVisible="{Binding HasDifferences}"
                                        Padding="8,4"
                                        FontSize="11" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>
