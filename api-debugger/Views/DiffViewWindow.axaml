<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MusicBeeRemote.ApiDebugger.ViewModels"
        xmlns:services="using:MusicBeeRemote.ApiDebugger.Services"
        x:Class="MusicBeeRemote.ApiDebugger.Views.DiffViewWindow"
        x:DataType="vm:DiffViewViewModel"
        Title="{Binding Context, StringFormat='Diff: {0}'}"
        Width="1200" Height="700"
        MinWidth="900" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="#1e1e1e">

    <Design.DataContext>
        <vm:DiffViewViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="16">
        <!-- Tab Buttons and Navigation -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,12">
            <!-- Left: Tab buttons -->
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <RadioButton Content="REQUEST" IsChecked="{Binding ShowRequest}"
                             GroupName="TabGroup" Margin="0,0,16,0"
                             IsEnabled="{Binding !IsLoading}"
                             Foreground="{Binding ShowRequest, Converter={x:Static vm:BoolToBrushConverter.Instance}}" />
                <RadioButton Content="RESPONSE" IsChecked="{Binding ShowResponse}"
                             GroupName="TabGroup"
                             IsEnabled="{Binding !IsLoading}"
                             Foreground="{Binding ShowResponse, Converter={x:Static vm:BoolToBrushConverter.Instance}}" />
                <TextBlock Text="{Binding StatusText}" Foreground="#808080" Margin="24,0,0,0"
                           VerticalAlignment="Center"
                           IsVisible="{Binding !IsLoading}" />
                <TextBlock Text="Loading diff..." Foreground="#DCDCAA" Margin="24,0,0,0"
                           VerticalAlignment="Center"
                           IsVisible="{Binding IsLoading}" />
            </StackPanel>

            <!-- Center: Stats -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="{Binding StatsText}" Foreground="#4EC9B0" FontWeight="SemiBold" />
            </StackPanel>

            <!-- Right: Diff navigation -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" IsVisible="{Binding TotalDiffs}">
                <Button Content="&#x25B2;" Command="{Binding PreviousDiffCommand}"
                        ToolTip.Tip="Previous difference"
                        Classes="secondary" Padding="8,4" FontSize="10" Margin="0,0,4,0" />
                <TextBlock VerticalAlignment="Center" Margin="4,0">
                    <Run Text="{Binding CurrentDiffIndex}" Foreground="#e0e0e0" />
                    <Run Text=" / " Foreground="#808080" />
                    <Run Text="{Binding TotalDiffs}" Foreground="#808080" />
                </TextBlock>
                <Button Content="&#x25BC;" Command="{Binding NextDiffCommand}"
                        ToolTip.Tip="Next difference"
                        Classes="secondary" Padding="8,4" FontSize="10" Margin="4,0,0,0" />
            </StackPanel>
        </Grid>

        <!-- Collapsible Differences Summary -->
        <Border Grid.Row="1" Background="#2d2020" CornerRadius="4" Padding="8" Margin="0,0,0,12"
                IsVisible="{Binding ShowSummary}">
            <Grid RowDefinitions="Auto,Auto">
                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <TextBlock Text="DIFFERENCES" Foreground="#F44747" FontWeight="SemiBold" FontSize="11" />
                    <Button Content="Hide" Command="{Binding ToggleSummaryCommand}"
                            Classes="secondary" Padding="4,2" FontSize="10" Margin="12,0,0,0" />
                </StackPanel>
                <ItemsControl Grid.Row="1" ItemsSource="{Binding Differences}" Margin="0,8,0,0"
                              IsVisible="{Binding Differences.Count}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Foreground="#F48771" FontFamily="Consolas" FontSize="11"
                                       Margin="0,1" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <!-- Show Summary Button when hidden -->
        <Button Grid.Row="1" Content="Show Differences Summary" Command="{Binding ToggleSummaryCommand}"
                Classes="secondary" Padding="8,4" FontSize="11" Margin="0,0,0,12"
                HorizontalAlignment="Left"
                IsVisible="{Binding !ShowSummary}" />

        <!-- Side-by-Side Diff View -->
        <Grid Grid.Row="2" ColumnDefinitions="*,8,*">
            <!-- Session A (Left) -->
            <Border Grid.Column="0" Background="#252526" CornerRadius="6" BorderBrush="#3d3d3d" BorderThickness="1">
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0" Background="#2d2d2d" CornerRadius="6,6,0,0" Padding="12,8">
                        <TextBlock Text="Session A (Baseline)" Foreground="#4EC9B0" FontWeight="SemiBold" />
                    </Border>
                    <ScrollViewer Grid.Row="1" x:Name="ScrollViewerA"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding LeftLines}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="services:DiffLine">
                                    <Border Background="{Binding Type, Converter={x:Static vm:DiffLineTypeToBackgroundConverter.Instance}}"
                                            Padding="0,1">
                                        <Grid ColumnDefinitions="30,16,*">
                                            <!-- Line number -->
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding LineNumberA}"
                                                       Foreground="#5a5a5a"
                                                       FontFamily="Cascadia Code, Consolas, monospace"
                                                       FontSize="11"
                                                       TextAlignment="Right"
                                                       Padding="4,0" />
                                            <!-- Gutter indicator -->
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Type, Converter={x:Static vm:DiffLineTypeToGutterConverter.Instance}}"
                                                       Foreground="{Binding Type, Converter={x:Static vm:DiffLineTypeToForegroundConverter.Instance}}"
                                                       FontFamily="Cascadia Code, Consolas, monospace"
                                                       FontSize="11"
                                                       FontWeight="Bold"
                                                       TextAlignment="Center" />
                                            <!-- Content - Simple text for non-segmented lines -->
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Text}"
                                                       Foreground="{Binding Type, Converter={x:Static vm:DiffLineTypeToForegroundConverter.Instance}}"
                                                       FontFamily="Cascadia Code, Consolas, monospace"
                                                       FontSize="12"
                                                       Padding="4,0"
                                                       IsVisible="{Binding !HasSegments}" />
                                            <!-- Content - Inline segments for modified lines -->
                                            <ItemsControl Grid.Column="2"
                                                          ItemsSource="{Binding Segments}"
                                                          IsVisible="{Binding HasSegments}"
                                                          Padding="4,0">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="services:DiffSegment">
                                                        <Border Background="{Binding IsChanged, Converter={x:Static vm:DiffSegmentToBackgroundConverter.Instance}}"
                                                                CornerRadius="2">
                                                            <TextBlock Text="{Binding Text}"
                                                                       Foreground="{Binding IsChanged, Converter={x:Static vm:DiffSegmentToForegroundConverter.Instance}}"
                                                                       FontFamily="Cascadia Code, Consolas, monospace"
                                                                       FontSize="12" />
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Session B (Right) -->
            <Border Grid.Column="2" Background="#252526" CornerRadius="6" BorderBrush="#3d3d3d" BorderThickness="1">
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0" Background="#2d2d2d" CornerRadius="6,6,0,0" Padding="12,8">
                        <TextBlock Text="Session B (Current)" Foreground="#DCDCAA" FontWeight="SemiBold" />
                    </Border>
                    <ScrollViewer Grid.Row="1" x:Name="ScrollViewerB"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding RightLines}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="services:DiffLine">
                                    <Border Background="{Binding Type, Converter={x:Static vm:DiffLineTypeToBackgroundConverter.Instance}}"
                                            Padding="0,1">
                                        <Grid ColumnDefinitions="30,16,*">
                                            <!-- Line number -->
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding LineNumberB}"
                                                       Foreground="#5a5a5a"
                                                       FontFamily="Cascadia Code, Consolas, monospace"
                                                       FontSize="11"
                                                       TextAlignment="Right"
                                                       Padding="4,0" />
                                            <!-- Gutter indicator -->
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Type, Converter={x:Static vm:DiffLineTypeToGutterConverter.Instance}}"
                                                       Foreground="{Binding Type, Converter={x:Static vm:DiffLineTypeToForegroundConverter.Instance}}"
                                                       FontFamily="Cascadia Code, Consolas, monospace"
                                                       FontSize="11"
                                                       FontWeight="Bold"
                                                       TextAlignment="Center" />
                                            <!-- Content - Simple text for non-segmented lines -->
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Text}"
                                                       Foreground="{Binding Type, Converter={x:Static vm:DiffLineTypeToForegroundConverter.Instance}}"
                                                       FontFamily="Cascadia Code, Consolas, monospace"
                                                       FontSize="12"
                                                       Padding="4,0"
                                                       IsVisible="{Binding !HasSegments}" />
                                            <!-- Content - Inline segments for modified lines -->
                                            <ItemsControl Grid.Column="2"
                                                          ItemsSource="{Binding Segments}"
                                                          IsVisible="{Binding HasSegments}"
                                                          Padding="4,0">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="services:DiffSegment">
                                                        <Border Background="{Binding IsChanged, Converter={x:Static vm:DiffSegmentToBackgroundConverter.Instance}}"
                                                                CornerRadius="2">
                                                            <TextBlock Text="{Binding Text}"
                                                                       Foreground="{Binding IsChanged, Converter={x:Static vm:DiffSegmentToForegroundConverter.Instance}}"
                                                                       FontFamily="Cascadia Code, Consolas, monospace"
                                                                       FontSize="12" />
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,12,0,0">
            <Button Content="Copy A" Command="{Binding CopyACommand}"
                    Classes="secondary" Margin="0,0,8,0" />
            <Button Content="Copy B" Command="{Binding CopyBCommand}"
                    Classes="secondary" Margin="0,0,24,0" />
            <Button Content="Close" Click="Close_Click"
                    Classes="secondary" />
        </StackPanel>
    </Grid>
</Window>
