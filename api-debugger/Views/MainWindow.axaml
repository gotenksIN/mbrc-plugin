<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MusicBeeRemote.ApiDebugger.ViewModels"
        xmlns:models="using:MusicBeeRemote.ApiDebugger.Models"
        x:Class="MusicBeeRemote.ApiDebugger.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="MusicBee Remote API Debugger"
        Width="1200" Height="750"
        MinWidth="1000" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e1e">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*" Margin="16">
        <!-- Top Row: Connection and Cover -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
            <!-- Connection Panel -->
            <Border Grid.Column="0" Classes="card" Margin="0,0,12,0">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="Auto,Auto,Auto,*">
                    <!-- Row 0: Client Type, Protocol, No Broadcast -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Client" Classes="label" Margin="0,0,8,8" />
                    <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{x:Static vm:MainWindowViewModel.ClientTypes}"
                              SelectedIndex="{Binding SelectedClientTypeIndex}" Width="100" Margin="0,0,16,8" />
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Protocol" Classes="label" Margin="0,0,8,8" />
                    <StackPanel Grid.Row="0" Grid.Column="3" Orientation="Horizontal">
                        <ComboBox ItemsSource="{x:Static vm:MainWindowViewModel.ProtocolVersions}"
                                  SelectedIndex="{Binding SelectedProtocolVersionIndex}" Width="70" Margin="0,0,16,8" />
                        <CheckBox Content="No broadcast" IsChecked="{Binding NoBroadcast}" VerticalAlignment="Center" Margin="0,0,0,8" />
                    </StackPanel>

                    <!-- Row 1: IP, Port -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Host" Classes="label" Margin="0,0,8,8" />
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding IpAddress}" Width="120" Margin="0,0,16,8" />
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Port" Classes="label" Margin="0,0,8,8" />
                    <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding Port}" Width="70" Margin="0,0,0,8" HorizontalAlignment="Left" />

                    <!-- Row 2: Buttons -->
                    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal" Margin="0,4,0,8">
                        <Button Content="Discover" Command="{Binding DiscoverCommand}" Classes="secondary" Margin="0,0,8,0" />
                        <Button Content="Connect" Command="{Binding ConnectCommand}" IsEnabled="{Binding CanConnect}" Classes="primary" Margin="0,0,8,0" />
                        <Button Content="Disconnect" Command="{Binding ExecuteDisconnectCommand}" IsEnabled="{Binding CanDisconnect}" Classes="secondary" Margin="0,0,8,0" />
                        <Button Content="Secondary..." Click="SecondaryConnection_Click" Classes="secondary" Margin="0,0,8,0" />
                        <Button Content="Proxy Mode..." Click="ProxyMode_Click" Classes="secondary" />
                    </StackPanel>

                    <!-- Row 3: Status -->
                    <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal">
                        <Ellipse Width="10" Height="10" Fill="{Binding StatusColor}" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}" TextWrapping="Wrap" FontSize="12" VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Cover Panel -->
            <Border Grid.Column="1" Classes="card" Width="150">
                <Grid RowDefinitions="Auto,110,Auto,Auto">
                    <TextBlock Grid.Row="0" Text="COVER" Classes="section-header" />
                    <Border Grid.Row="1" Classes="image-container" Width="110" Height="110">
                        <Image Source="{Binding CoverImage}" Stretch="Uniform" Margin="4" />
                    </Border>
                    <TextBlock Grid.Row="2" Text="{Binding CoverStatus}" Foreground="{Binding CoverStatusColor}"
                               TextWrapping="Wrap" Margin="0,8,0,0" FontSize="11" />
                    <Button Grid.Row="3" Content="Test" Command="{Binding TestCoverCommand}"
                            Classes="secondary" HorizontalAlignment="Left" Margin="0,8,0,0" />
                </Grid>
            </Border>
        </Grid>

        <!-- Bottom Row: Commands+JSON, Lyrics, Messages -->
        <Grid Grid.Row="1" ColumnDefinitions="400,*,*">
            <!-- JSON Payload with Command Selection -->
            <Border Grid.Column="0" Classes="card" Margin="0,0,12,0">
                <Grid RowDefinitions="Auto,Auto,*,Auto">
                    <!-- Command Selection -->
                    <TextBlock Grid.Row="0" Text="PROTOCOL COMMAND" Classes="section-header" />
                    <ComboBox Grid.Row="1" ItemsSource="{Binding ProtocolCommands}"
                              SelectedItem="{Binding SelectedCommand}" HorizontalAlignment="Stretch" Margin="0,0,0,12" FontSize="13">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}" FontSize="13" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- JSON Payload Editor -->
                    <TextBox Grid.Row="2" x:Name="JsonPayloadEditor"
                             Text="{Binding JsonPayload}"
                             Classes="code"
                             AcceptsReturn="True"
                             TextWrapping="NoWrap"
                             Foreground="#D4D4D4" />
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="Send JSON" Command="{Binding SendJsonCommand}"
                                IsEnabled="{Binding CanSendCommands}" Classes="primary" Margin="0,0,8,0" />
                        <Button Content="Prettify" Command="{Binding PrettifyJsonCommand}" Classes="secondary" Margin="0,0,8,0" />
                        <Button Content="Preview" Click="PreviewJson_Click" Classes="secondary" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Lyrics Display -->
            <Border Grid.Column="1" Classes="card" Margin="0,0,12,0">
                <Grid RowDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Row="0" Text="LYRICS" Classes="section-header" />
                    <TextBox Grid.Row="1" Text="{Binding LyricsText}" IsReadOnly="True" Classes="code"
                             AcceptsReturn="True" TextWrapping="Wrap" />
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
                        <TextBlock Text="{Binding LyricsStatus}" Foreground="{Binding LyricsStatusColor}"
                                   VerticalAlignment="Center" FontSize="11" Margin="0,0,12,0" />
                        <Button Content="Test" Command="{Binding TestLyricsCommand}" Classes="secondary" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Messages Panel -->
            <Border Grid.Column="2" Classes="card">
                <Grid RowDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Row="0" Text="MESSAGES" Classes="section-header" />
                    <ListBox Grid.Row="1" x:Name="MessagesListBox" ItemsSource="{Binding CurrentMessages}" Classes="code"
                             SelectedIndex="{Binding SelectedLogIndex}"
                             DoubleTapped="MessagesList_DoubleTapped">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:LogMessage">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{Binding TimestampText}" Foreground="#808080" FontFamily="Consolas" FontSize="12" />
                                    <TextBlock Text="{Binding DirectionIndicator}" Foreground="{Binding DirectionColor}" FontFamily="Consolas" FontSize="12" FontWeight="Bold" Width="14" />
                                    <TextBlock Text="{Binding JsonIndicator}" Foreground="#CE9178" FontFamily="Consolas" FontSize="12" Width="18" />
                                    <TextBlock Text="{Binding Content}" Foreground="{Binding Color}" FontFamily="Consolas" FontSize="12" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
                        <CheckBox Content="Received only" IsChecked="{Binding FilterReceivedOnly}"
                                  VerticalAlignment="Center" Margin="0,0,12,0" FontSize="12" />
                        <Button Content="Clear" Command="{Binding ClearMessagesCommand}" Classes="secondary" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
