<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MusicBeeRemote.ApiDebugger.ViewModels"
        xmlns:models="using:MusicBeeRemote.ApiDebugger.Models"
        x:Class="MusicBeeRemote.ApiDebugger.Views.ProxyWindow"
        x:DataType="vm:ProxyWindowViewModel"
        Title="Proxy Mode - MusicBee Remote API Debugger"
        Width="1100" Height="750"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e1e">

    <Design.DataContext>
        <vm:ProxyWindowViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="16">
        <!-- Configuration Panel -->
        <Border Grid.Row="0" Classes="card" Margin="0,0,0,12">
            <Grid RowDefinitions="Auto,Auto,Auto">
                <TextBlock Grid.Row="0" Text="PROXY CONFIGURATION" Classes="section-header" />

                <!-- Port and Host Configuration -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="Listen Port" Classes="label" Margin="0,0,8,0" />
                    <TextBox Text="{Binding ListenPort}" Width="70" Margin="0,0,24,0"
                             IsEnabled="{Binding CanEditConfig}" />
                    <TextBlock Text="Target Host" Classes="label" Margin="0,0,8,0" />
                    <TextBox Text="{Binding TargetHost}" Width="120" Margin="0,0,8,0"
                             IsEnabled="{Binding CanEditConfig}" />
                    <TextBlock Text=":" Classes="label" Margin="0,0,8,0" />
                    <TextBox Text="{Binding TargetPort}" Width="70" Margin="0,0,24,0"
                             IsEnabled="{Binding CanEditConfig}" />

                    <!-- Control Buttons -->
                    <Button Content="Start Proxy" Command="{Binding StartProxyCommand}"
                            IsEnabled="{Binding CanStart}" Classes="primary" Margin="0,0,8,0" />
                    <Button Content="Stop" Command="{Binding StopProxyCommand}"
                            IsEnabled="{Binding CanStop}" Classes="secondary" Margin="0,0,24,0" />

                    <!-- Status Indicator -->
                    <Ellipse Width="10" Height="10" Fill="{Binding StatusColor}" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}"
                               VerticalAlignment="Center" FontSize="13" Margin="0,0,24,0" />

                    <!-- Connection Count -->
                    <TextBlock Text="Connections:" Classes="label" Margin="0,0,8,0" />
                    <TextBlock Text="{Binding ConnectionCountText}" Foreground="#4EC9B0"
                               VerticalAlignment="Center" FontWeight="SemiBold" FontSize="14" />
                </StackPanel>

                <!-- Filter Options -->
                <StackPanel Grid.Row="2" Orientation="Horizontal">
                    <CheckBox Content="App to Plugin" IsChecked="{Binding FilterAppToPlugin}"
                              VerticalAlignment="Center" Margin="0,0,16,0" FontSize="12" />
                    <CheckBox Content="Plugin to App" IsChecked="{Binding FilterPluginToApp}"
                              VerticalAlignment="Center" Margin="0,0,24,0" FontSize="12" />
                    <TextBlock Text="Search:" Classes="label" Margin="0,0,8,0" />
                    <TextBox Text="{Binding SearchFilter}" Width="150" Watermark="Filter by context..."
                             Margin="0,0,24,0" />
                    <Button Content="Clear Messages" Command="{Binding ClearMessagesCommand}"
                            Classes="secondary" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Session Recording Panel -->
        <Border Grid.Row="1" Classes="card" Margin="0,0,0,12">
            <Grid RowDefinitions="Auto,Auto">
                <TextBlock Grid.Row="0" Text="SESSION RECORDING" Classes="section-header" />

                <StackPanel Grid.Row="1" Orientation="Horizontal">
                    <TextBlock Text="Session Name:" Classes="label" Margin="0,0,8,0" />
                    <TextBox Text="{Binding SessionName}" Width="200" Watermark="e.g., Release v1.0"
                             Margin="0,0,16,0" IsEnabled="{Binding !IsRecording}" />

                    <Button Content="● Record" Command="{Binding StartRecordingCommand}"
                            IsEnabled="{Binding CanStartRecording}" Classes="primary" Margin="0,0,8,0" />
                    <Button Content="■ Stop" Command="{Binding StopRecordingCommand}"
                            IsEnabled="{Binding IsRecording}" Classes="secondary" Margin="0,0,16,0" />

                    <Button Content="Save..." Command="{Binding SaveSessionCommand}"
                            IsEnabled="{Binding CanSaveSession}" Classes="secondary" Margin="0,0,8,0" />
                    <Button Content="Load..." Command="{Binding LoadSessionCommand}"
                            IsEnabled="{Binding !IsRecording}" Classes="secondary" Margin="0,0,24,0" />

                    <!-- Recording Status -->
                    <TextBlock Text="{Binding RecordingStatusText}" Foreground="#DCDCAA"
                               VerticalAlignment="Center" FontSize="13" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Session Comparison Panel -->
        <Border Grid.Row="2" Classes="card" Margin="0,0,0,12"
                IsVisible="{Binding HasLoadedSessions}">
            <Grid RowDefinitions="Auto,Auto">
                <TextBlock Grid.Row="0" Text="SESSION COMPARISON" Classes="section-header" />

                <StackPanel Grid.Row="1" Orientation="Horizontal">
                    <TextBlock Text="Session A:" Classes="label" Margin="0,0,8,0" />
                    <ComboBox ItemsSource="{Binding LoadedSessions}"
                              SelectedItem="{Binding SelectedSessionA}"
                              Width="200" Margin="0,0,16,0">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="models:RecordedSession">
                                <TextBlock Text="{Binding DisplayName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="Session B:" Classes="label" Margin="0,0,8,0" />
                    <ComboBox ItemsSource="{Binding LoadedSessions}"
                              SelectedItem="{Binding SelectedSessionB}"
                              Width="200" Margin="0,0,16,0">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="models:RecordedSession">
                                <TextBlock Text="{Binding DisplayName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <Button Command="{Binding CompareSessionsCommand}"
                            IsEnabled="{Binding CanCompareSessions}" Classes="primary" Margin="0,0,16,0">
                        <Panel>
                            <TextBlock Text="Compare" IsVisible="{Binding !IsComparing}" />
                            <TextBlock Text="Comparing..." IsVisible="{Binding IsComparing}" />
                        </Panel>
                    </Button>

                    <TextBlock Text="Ignore:" Classes="label" Margin="0,0,8,0" />
                    <TextBox Text="{Binding IgnoreFields}" Width="150" Watermark="client_id, timestamp"
                             Margin="0,0,8,0" />
                    <CheckBox Content="Ignore array order" IsChecked="{Binding IgnoreArrayOrder}"
                              VerticalAlignment="Center" FontSize="12" Margin="0,0,16,0" />
                    <Button Content="Clear Sessions" Command="{Binding ClearSessionsCommand}"
                            Classes="secondary" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Message Log and Detail View -->
        <Grid Grid.Row="3" ColumnDefinitions="*,*">
            <!-- Intercepted Messages List -->
            <Border Grid.Column="0" Classes="card" Margin="0,0,6,0">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" Text="INTERCEPTED MESSAGES" Classes="section-header" />
                    <ListBox Grid.Row="1" x:Name="MessagesListBox"
                             ItemsSource="{Binding FilteredMessages}"
                             SelectedItem="{Binding SelectedMessage}"
                             Classes="code"
                             DoubleTapped="MessagesList_DoubleTapped">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:LogMessage">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{Binding TimestampText}" Foreground="#808080" FontFamily="Consolas" FontSize="12" />
                                    <TextBlock Text="{Binding DirectionIndicator}" Foreground="{Binding DirectionColor}" FontFamily="Consolas" FontSize="12" FontWeight="Bold" Width="14" />
                                    <TextBlock Text="{Binding JsonIndicator}" Foreground="#CE9178" FontFamily="Consolas" FontSize="12" Width="18" />
                                    <TextBlock Text="{Binding Content}" Foreground="{Binding Color}" FontFamily="Consolas" FontSize="12" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Selected Message Detail -->
            <Border Grid.Column="1" Classes="card" Margin="6,0,0,0">
                <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">
                    <!-- Header with size info -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="SELECTED MESSAGE" Classes="section-header" Margin="0" />
                        <TextBlock Text="{Binding JsonSizeInfo}" Foreground="#808080" FontSize="11"
                                   VerticalAlignment="Center" Margin="12,0,0,0"
                                   IsVisible="{Binding HasSelectedMessage}" />
                        <TextBlock Text="Loading..." Foreground="#DCDCAA" FontSize="11"
                                   VerticalAlignment="Center" Margin="12,0,0,0"
                                   IsVisible="{Binding IsLoadingJson}" />
                    </StackPanel>

                    <!-- Cover Preview (visible when cover detected) -->
                    <Border Grid.Row="1" IsVisible="{Binding HasCover}" Margin="0,0,0,12">
                        <Grid ColumnDefinitions="Auto,*">
                            <Border Grid.Column="0" Classes="image-container" Width="100" Height="100">
                                <Image Source="{Binding CoverImage}" Stretch="Uniform" Margin="4" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                <TextBlock Text="Cover Image Detected" Foreground="#4EC9B0" FontWeight="SemiBold" FontSize="13" />
                                <TextBlock Text="Image preview from nowplayingcover response" Foreground="#808080" FontSize="11" Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Truncation Warning -->
                    <Border Grid.Row="2" IsVisible="{Binding IsJsonTruncated}" Background="#3d3d00"
                            BorderBrush="#5d5d00" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Large JSON truncated for performance." Foreground="#DCDCAA" FontSize="12"
                                       VerticalAlignment="Center" Margin="0,0,12,0" />
                            <Button Content="Load Full JSON" Command="{Binding LoadFullJsonCommand}"
                                    Padding="8,4" FontSize="11" />
                        </StackPanel>
                    </Border>

                    <!-- JSON Content -->
                    <Border Grid.Row="3" Background="#1e1e1e" BorderBrush="#3d3d3d" BorderThickness="1" CornerRadius="6">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <SelectableTextBlock x:Name="SelectedMessageTextBlock"
                                                 FontFamily="Cascadia Code, Consolas, monospace"
                                                 FontSize="13"
                                                 Padding="12"
                                                 TextWrapping="NoWrap" />
                        </ScrollViewer>
                    </Border>

                    <!-- Action Buttons -->
                    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="Copy JSON" Command="{Binding CopyMessageCommand}"
                                IsEnabled="{Binding HasSelectedMessage}" Classes="secondary" Margin="0,0,8,0" />
                        <Button Content="Expand..." Click="ExpandJson_Click"
                                IsEnabled="{Binding HasSelectedMessage}" Classes="secondary" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
