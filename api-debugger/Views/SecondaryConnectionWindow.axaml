<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MusicBeeRemote.ApiDebugger.ViewModels"
        xmlns:models="using:MusicBeeRemote.ApiDebugger.Models"
        x:Class="MusicBeeRemote.ApiDebugger.Views.SecondaryConnectionWindow"
        x:DataType="vm:SecondaryConnectionViewModel"
        Title="{Binding Title}"
        Width="1000" Height="700"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e1e">

    <Design.DataContext>
        <vm:SecondaryConnectionViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,*" Margin="16">
        <!-- Connection Panel -->
        <Border Grid.Row="0" Classes="card" Margin="0,0,0,12">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0">
                    <TextBlock Text="CONNECTION" Classes="section-header" />
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Connect (No-Broadcast)" Command="{Binding ConnectCommand}"
                                IsEnabled="{Binding CanConnect}" Classes="primary" Margin="0,0,12,0" />
                        <Button Content="Disconnect" Command="{Binding DisconnectCommand}"
                                IsEnabled="{Binding CanDisconnect}" Classes="secondary" Margin="0,0,24,0" />
                        <Ellipse Width="10" Height="10" Fill="{Binding StatusColor}" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}"
                                   VerticalAlignment="Center" FontSize="13" Margin="0,0,24,0" />
                        <TextBlock Text="{Binding ClientIdText}" FontFamily="Cascadia Code, Consolas, monospace"
                                   Foreground="#808080" VerticalAlignment="Center" FontSize="12" />
                    </StackPanel>
                </StackPanel>

                <!-- Cover preview -->
                <Border Grid.Column="1" Classes="image-container" Width="60" Height="60">
                    <Image Source="{Binding CoverImage}" Stretch="Uniform" Margin="4" />
                </Border>
            </Grid>
        </Border>

        <!-- API Testing Panel -->
        <Border Grid.Row="1" Classes="card" Margin="0,0,0,12" IsEnabled="{Binding CanTest}">
            <StackPanel>
                <TextBlock Text="API TESTING" Classes="section-header" />
                <!-- Simple commands -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <Button Content="Player Status" Command="{Binding TestPlayerStatusCommand}" Classes="secondary" Margin="0,0,8,0" />
                    <Button Content="Track Info" Command="{Binding TestTrackInfoCommand}" Classes="secondary" Margin="0,0,8,0" />
                    <Button Content="Cover" Command="{Binding TestCoverCommand}" Classes="secondary" />
                </StackPanel>
                <!-- Paginated commands -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <ComboBox ItemsSource="{x:Static vm:SecondaryConnectionViewModel.PaginatedCommands}"
                              SelectedIndex="{Binding SelectedPaginatedCommandIndex}" Width="220" Margin="0,0,8,0" />
                    <TextBlock Text="Offset" Classes="label" Margin="0,0,8,0" />
                    <TextBox Text="{Binding Offset}" Width="50" Margin="0,0,8,0" />
                    <TextBlock Text="Limit" Classes="label" Margin="0,0,8,0" />
                    <TextBox Text="{Binding Limit}" Width="50" Margin="0,0,8,0" />
                    <Button Content="Send" Command="{Binding SendPaginatedCommand}" Classes="primary" />
                </StackPanel>
                <!-- Utility buttons -->
                <StackPanel Orientation="Horizontal">
                    <Button Content="Save Response" Command="{Binding SaveResponseCommand}" Classes="secondary" Margin="0,0,8,0" />
                    <Button Content="Clear Saved" Command="{Binding ClearSavedResponseCommand}" Classes="secondary" Margin="0,0,8,0" />
                    <Button Content="Compare" Command="{Binding CompareResponseCommand}" Classes="secondary" Margin="0,0,8,0" />
                    <Button Content="Clear Log" Command="{Binding ClearLogCommand}" Classes="secondary" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Log and Response Display -->
        <Grid Grid.Row="2" ColumnDefinitions="*,*">
            <!-- Connection Log -->
            <Border Grid.Column="0" Classes="card" Margin="0,0,6,0">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" Text="CONNECTION LOG" Classes="section-header" />
                    <ListBox Grid.Row="1" x:Name="LogListBox" ItemsSource="{Binding LogMessages}" Classes="code"
                             DoubleTapped="LogList_DoubleTapped">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:LogMessage">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{Binding TimestampText}" Foreground="#808080" FontFamily="Consolas" FontSize="12" />
                                    <TextBlock Text="{Binding DirectionIndicator}" Foreground="{Binding DirectionColor}" FontFamily="Consolas" FontSize="12" FontWeight="Bold" Width="14" />
                                    <TextBlock Text="{Binding JsonIndicator}" Foreground="#CE9178" FontFamily="Consolas" FontSize="12" Width="18" />
                                    <TextBlock Text="{Binding Content}" Foreground="{Binding Color}" FontFamily="Consolas" FontSize="12" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Last Response -->
            <Border Grid.Column="1" Classes="card" Margin="6,0,0,0">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" Text="LAST RESPONSE" Classes="section-header" />
                    <Border Grid.Row="1" Background="#1e1e1e" BorderBrush="#3d3d3d" BorderThickness="1" CornerRadius="6">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <SelectableTextBlock x:Name="ResponseTextBlock"
                                                 FontFamily="Cascadia Code, Consolas, monospace"
                                                 FontSize="13"
                                                 Padding="12"
                                                 TextWrapping="NoWrap" />
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
